# Copy to .env (gitignored) and fill in. Used by fix-issue.ts and relay.ts.

# Anthropic API key — bills + authorizes the Managed Agent.
ANTHROPIC_API_KEY=sk-ant-...

# Repo-scoped fine-grained PAT the agent uses to push branches + open PRs.
# Scopes: Contents (RW), Pull requests (RW), Issues (RW) on this repo only.
# (NOT your broad `gh auth token`.)
GITHUB_TOKEN=github_pat_...

# relay.ts only: shared secret you also paste into the GitHub webhook's
# "Secret" field. Any long random string. Verifies X-Hub-Signature-256.
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Optional: relay listen port (default 8788).
# PORT=8788

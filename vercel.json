{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/my-photography-profile"
      }
    }
  ],
  "routes": [
    {
      "src": "/(assets|favicon.ico|main.*|polyfills.*|runtime.*|scripts.*|styles.*|browser.*)",
      "dest": "/$1"
    },
    {
      "src": "/*",
      "dest": "/index.html"
    }
  ]
}
